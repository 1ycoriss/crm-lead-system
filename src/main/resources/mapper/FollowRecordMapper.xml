<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.crm.lead.mapper.FollowRecordMapper">

    <insert id="insert" parameterType="com.crm.lead.entity.FollowRecord">
        insert into follow_record
        (
            lead_id,
            follow_user_id,
            follow_type,
            follow_result,
            content,
            next_follow_time
        )
        values
            (
                #{leadId},
                #{followUserId},
                #{followType},
                #{followResult},
                #{content},
                #{nextFollowTime}
            )
    </insert>

</mapper>