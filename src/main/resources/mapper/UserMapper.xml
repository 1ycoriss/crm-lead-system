<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.crm.lead.mapper.UserMapper">

    <select id="selectByUsername" resultType="com.crm.lead.entity.SysUser">
        select
            id,
            username,
            password,
            real_name,
            role,
            status,
            create_time,
            update_time
        from sys_user
        where username = #{username}
    </select>

</mapper>